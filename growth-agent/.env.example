# ─── LLM ─────────────────────────────────────────────────────────────────────
# Provide ONE of these. Priority: OpenAI → Anthropic → Gemini (free tier).
OPENAI_API_KEY=sk-...          # gpt-4o-mini when this is set
ANTHROPIC_API_KEY=sk-ant-...   # claude-3-5-haiku-20241022 when this is set
GOOGLE_API_KEY=AIza...         # gemini-1.5-flash (free tier, ~0 cost for low usage)

# ─── Analytics endpoint (internal) ───────────────────────────────────────────
# Base URL of the deployed calculadora app
APP_BASE_URL=https://calculadora.dbcdatastudio.com
# Must match ANALYTICS_SECRET set in the Vercel project env vars
ANALYTICS_SECRET=your-strong-random-secret-here

# ─── GA4 (direct access, alternative to the internal endpoint) ───────────────
# Google Service Account JSON with GA4 Viewer access (single-line JSON string)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GA4_PROPERTY_ID=properties/525217735

# ─── Facebook Groups (primary outreach channel) ───────────────────────────────
# Without these, the agent still works — it uses the built-in curated group list.
# To enable live post fetching from specific groups you're a member of:
#   1. Go to https://developers.facebook.com → create an App
#   2. Use Graph API Explorer to get a User Token with groups_access_member_info
#   3. Find group numeric IDs from the group URL or Graph API
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_GROUP_IDS=                    # comma-separated numeric IDs, e.g. 123456,789012

# ─── YouTube (strong secondary channel) ──────────────────────────────────────
# Create an API key at https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=

# ─── Email notifications (reports delivered to your inbox) ───────────────────
# RESEND_API_KEY — from https://resend.com/api-keys (you already use Resend in Abigail)
# NOTIFY_EMAIL   — where to send the daily digest (your personal email)
# NOTIFY_FROM    — sender address. Use "onboarding@resend.dev" for Resend's shared domain
#                  (no setup needed) or "agent@yourdomain.com" if you have a verified domain.

