# ─── LLM ─────────────────────────────────────────────────────────────────────
# Anthropic API key for Claude claude-sonnet-4-5
ANTHROPIC_API_KEY=sk-ant-...

# ─── Analytics endpoint (internal) ───────────────────────────────────────────
# Base URL of the deployed calculadora app
APP_BASE_URL=https://calculadora.dbcdatastudio.com
# Must match ANALYTICS_SECRET set in the Vercel project env vars
ANALYTICS_SECRET=your-strong-random-secret-here

# ─── GA4 (direct access, alternative to the internal endpoint) ───────────────
# Google Service Account JSON with GA4 Viewer access (single-line JSON string)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GA4_PROPERTY_ID=properties/525217735

# ─── Reddit (optional — enables ContentOutreachAgent Reddit search) ───────────
# Create an app at https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=growth-agent/1.0 by u/your_reddit_username

# ─── YouTube (optional — enables ContentOutreachAgent YouTube search) ─────────
# Create an API key at https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=

# ─── Notifications (future use) ──────────────────────────────────────────────
# Uncomment and fill when you want reports sent automatically
# NOTIFY_EMAIL=you@example.com
# RESEND_API_KEY=re_...
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
